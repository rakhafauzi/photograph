{
  "name": "fotografi-booking-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "build": "npm run build:client && npm run build:server",
    "build:server": "npm run db:generate -w apps/server && npm run build -w apps/server",
    "build:client": "npm run build -w apps/client",
    "start": "node apps/server/dist/index.js",
    "db:push": "npm run db:push -w apps/server",
    "db:generate": "npm run db:generate -w apps/server",
    "db:studio": "npm run db:studio -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
